{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:canary": "vite build --mode canary",
    "lint": "eslint .",
    "preview": "vite preview",
    "cypress:info": "cypress info",
    "cypress:open": "cypress open --browser=chrome",
    "cypress:run": "cypress run",
    "cypress:cov": "npx nyc report",
    "cypress:cov:report": "npx nyc report --reporter=text-summary",
    "cypress:merge": "mochawesome-merge cypress/reports/*.json > cypress/reports/merged.json",
    "cypress:report": "marge cypress/reports/merged.json --reportDir cypress/reports/html --inline",
    "cypress:full": "rm -rf cypress/reports && npm run cypress:run && npm run cypress:merge && npm run cypress:report",
    "play:run": "playwright test",
    "play:open": "playwright test --ui",
    "play:report": "playwright show-report playwright/reports"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "jwt-decode": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^4.0.3",
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "cypress": "^15.14.1",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "vite": "^6.1.0",
    "vite-plugin-istanbul": "^8.0.0"
  }
}
